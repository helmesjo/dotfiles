# Environment variables for windows (MSYS2/UCRT64).
# Sourced by .zshrc/.bashrc via: set -a; source ~/.env; set +a

# System
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
COLORTERM=truecolor

# Editor
VISUAL=hx
EDITOR=$VISUAL

# WSL interop
HOST___HOME=$HOME
HOST___PROGRAMFILES=$PROGRAMFILES
WSLENV=HOST___HOME/p:HOST___PROGRAMFILES/p
