## y=yazi:
# changes the current working
# directory when exiting yazi
function _yazi() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  command yazi "$@" --cwd-file="$tmp"
  IFS= read -r -d '' cwd < "$tmp"
  [ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
  rm -f -- "$tmp"
}
alias y=_yazi

# alias for 'view in file manager' on various platforms
function _open_file_explorer() {
  local tgt_path="${1:-.}"
  if [[ ! -e "$tgt_path" ]]; then
    command $tgt_path
    return $?
  fi
  case "$(uname -s)" in
    Linux)
      xdg-open "$tgt_path" 2>/dev/null || gio open "$tgt_path" 2>/dev/null || nautilus "$tgt_path" 2>/dev/null
      ;;
    MINGW*|MSYS*|CYGWIN*)
      explorer "$(cygpath -w "$tgt_path")" >/dev/null 2>&1 & disown
      ;;
    *)
      echo "Unsupported platform: $(uname -s)" >&2
      return 1
      ;;
  esac
}

## erdtree:
# Translates common POSIX ls/tree flags to erdtree equivalents.
# Handles bundles (-lah), sort flags (-t/-S/-r), and conflicts (-d/-i/-s).
function _erdtree() {
  local -a newargs=()
  local arg flags f
  local sort_val=""  # default "name" applied after loop
  local reverse=0
  local eat_sort=0   # consume next arg as sort value

  for arg in "$@"; do
    # Consume value for -s / --sort; translate ls sort names to erdtree
    if (( eat_sort )); then
      case "$arg" in
        time)      sort_val="mod" ;;
        size)      sort_val="size" ;;
        name|none) sort_val="name" ;;
        *)         sort_val="$arg" ;;  # assume already an erdtree value (rmod, rsize, etc.)
      esac
      eat_sort=0
      continue
    fi

    # === Bundled short flags (e.g. -lah, -rta) ===
    if [[ $arg =~ ^-[a-zA-Z]+$ && ${#arg} -gt 2 ]]; then
      flags="${arg#-}"
      while [[ -n $flags ]]; do
        f="${flags%%${flags#?}}"
        case "$f" in
          a|A) newargs+=("-.") ;;           # -a/-A -> show hidden
          h)   newargs+=("-H") ;;           # -h    -> human-readable
          l)   newargs+=("--long") ;;       # -l    -> long format (ls)
          i)   newargs+=("--ino") ;;        # -i    -> inode number (not erdtree --no-ignore)
          s)   ;;                           # -s    -> skip (ls block-sizes; -H already shows sizes)
          S)   sort_val="size" ;;           # -S    -> sort by size (ls)
          r)   reverse=1 ;;                # -r    -> reverse sort (ls/tree)
          t)   sort_val="mod" ;;           # -t    -> sort by mtime (not erdtree --file-type)
          c)   sort_val="create" ;;         # -c    -> sort by ctime (ls)
          u)   sort_val="access" ;;         # -u    -> sort by atime (ls)
          d)   newargs+=("--dirs-only") ;;  # -d    -> dirs only (not erdtree --disk-usage)
          R)   newargs+=("-L" "999") ;;    # -R    -> all levels / recursive (ls)
          *)   newargs+=("-$f") ;;
        esac
        flags="${flags#?}"
      done
      continue
    fi

    # === Standalone flags ===
    case "$arg" in
      -s|--sort)                eat_sort=1 ;;   # consume next arg as sort value
      --sort=time)              sort_val="mod" ;;
      --sort=size)              sort_val="size" ;;
      --sort=name|--sort=none)  sort_val="name" ;;
      --sort=*)                 sort_val="${arg#--sort=}" ;;  # erdtree value passed directly
      -a|-A|--all|--almost-all) newargs+=("-." "--no-ignore") ;;
      -h|--human-readable)      newargs+=("-H") ;;
      -l)                       newargs+=("--long") ;;
      -i|--inode)               newargs+=("--ino") ;;
      -S)                       sort_val="size" ;;
      -r|--reverse)             reverse=1 ;;
      -t)                       sort_val="mod" ;;
      -c)                       sort_val="create" ;;
      -u)                       sort_val="access" ;;
      -d|--directory)           newargs+=("--dirs-only") ;;
      -R|--recursive)           newargs+=("-L" "999") ;;
      *)                        newargs+=("$arg") ;;
    esac
  done

  # Synthesize sort, toggling reverse via r-prefix
  [[ -z "$sort_val" ]] && sort_val="name"
  if (( reverse )); then
    [[ $sort_val == r* ]] && sort_val="${sort_val#r}" || sort_val="r${sort_val}"
  fi
  # Prepend sort so the path arg remains last in newargs
  newargs=("-s" "$sort_val" "${newargs[@]}")

  if [[ -d "${@: -1}" || ! -f "${@: -1}" ]]; then
    command erd "${newargs[@]}"
  else # deal with non-dir path
    local last="${newargs[-1]}"
    local dir="${last%/*}"
    local base="${last##*/}"
    # fix relative base paths
    [[ "$last" == "$base" || -z "$dir" || "$dir" == "$last" ]] && dir="."

    if [[ $OSTYPE != cygwin ]]; then
      newargs=("${newargs[@]:0:${#newargs[@]}-1}" --pattern "${base}" "$dir")
    else
      # handle implied extension
      newargs=("${newargs[@]:0:${#newargs[@]}-1}" --pattern "${base}(?:\..+)?$" "$dir")
    fi
    command erd "${newargs[@]}"
  fi
}
if [[ $OSTYPE != cygwin && $OSTYPE != msys ]]; then
  alias ll='_erdtree -H -I --disk-usage physical --layout inverted --long --no-ignore --no-progress -L1'
else
  # no permission info (erd --long) on Windows/msys2/cygwin
  alias ll='_erdtree -H -I --disk-usage physical --layout inverted --no-ignore --no-progress -L1'
fi
alias tree='_erdtree -H -I --disk-usage physical --layout inverted --no-progress'

_claude_run() { CLAUDE_CONFIG_DIR=$1 command claude "${@:2}"; }
alias claude='_claude_run ~/.config/claude/personal'
alias claude-work='_claude_run ~/.config/claude/work'

## File completion for aliases
#

# completion function for _open_file_explorer
function _files_completion() {
  _files -/  # Completes files and directories
}

if [[ -n "$ZSH_VERSION" ]]; then
  compdef _files_completion _open_file_explorer
  compdef _files_completion _erdtree
else
  complete -F _files_completion _open_file_explorer
  complete -F _files_completion _erdtree
fi
