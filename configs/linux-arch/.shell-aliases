# Make sudo work with other aliases
alias sudo='sudo '
alias win32yank='win32yank --lf'
alias cat='bat'
alias config='git -C $dotfiles_root'
if [[ $OSTYPE != cygwin ]]; then
  alias ll='erd -HI -d physical -s name -y inverted --long --no-ignore --no-progress -L 1'
else
  # no permission info (erd --long) on non-unix
  alias ll='erd -HI -d physical -s name -y inverted --no-ignore --no-progress -L 1'
fi
alias tree='erd -HI -d physical -s name -y inverted --no-ignore --no-progress'
alias fg1='fg %1'
alias fg2='fg %2'
alias fg3='fg %3'
alias fg4='fg %4'
alias fg5='fg %5'
alias fg6='fg %6'
alias fg7='fg %7'
alias fg8='fg %8'
alias fg9='fg %9'
