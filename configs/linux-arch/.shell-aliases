## y=yazi:
# changes the current working
# directory when exiting yazi
function _yazi() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  command yazi "$@" --cwd-file="$tmp"
  IFS= read -r -d '' cwd < "$tmp"
  [ "$cwd" != "$PWD" ] && [ -d "$cwd" ] && builtin cd -- "$cwd"
  rm -f -- "$tmp"
}
alias y=_yazi

# alias for 'view in file manager' on various platforms
function _open_file_explorer() {
  local tgt_path="${1:-.}"
  if [[ ! -e "$tgt_path" ]]; then
    command $tgt_path
    return $?
  fi
  case "$(uname -s)" in
    Linux)
      xdg-open "$tgt_path" 2>/dev/null || gio open "$tgt_path" 2>/dev/null || nautilus "$tgt_path" 2>/dev/null
      ;;
    MINGW*|MSYS*|CYGWIN*)
      explorer "$(cygpath -w "$tgt_path")" >/dev/null 2>&1 & disown
      ;;
    *)
      echo "Unsupported platform: $(uname -s)" >&2
      return 1
      ;;
  esac
}

## erdtree:
# Converts common POSIX ls/tree flags (-a, -h, -l and bundles like -lah)
# to the equivalent erdtree short flags on the fly.
function _erdtree() {
  local -a newargs=()
  local arg flags f

  for arg in "$@"; do
    # === Handle bundled POSIX short flags (e.g. -lah, -al, -Lah, etc.) ===
    if [[ $arg =~ ^-[a-zA-Z]+$ && ${#arg} -gt 2 ]]; then
      flags="${arg#-}"
      while [[ -n $flags ]]; do
        # Extract first character (portable in Bash + Zsh)
        f="${flags%%${flags#?}}"
        case "$f" in
          a) newargs+=("-.") ;;   # -a → -.
          h) newargs+=("-H") ;;   # -h → -H
          l) newargs+=("-l") ;;   # -l → -l
          *) newargs+=("-$f") ;;  # everything else unchanged
        esac
        flags="${flags#?}"        # remove first character
      done
      continue
    fi

    # === Handle standalone common POSIX flags ===
    case "$arg" in
      -a) newargs+=("-.") ;;
      -h) newargs+=("-H") ;;
      -l) newargs+=("-l") ;;
      *)  newargs+=("$arg") ;;  # paths, -L 5, --help, etc. untouched
    esac
  done

  if [[ -d "${@: -1}" || ! -f "${@: -1}" ]]; then
    command erd "${newargs[@]}"
  else # deal with non-dir path
    local last="${newargs[-1]}"
    local dir="${last%/*}"
    local base="${last##*/}"
    # fix relative base paths
    [[ "$last" == "$base" || -z "$dir" || "$dir" == "$last" ]] && dir="."

    if [[ $OSTYPE != cygwin ]]; then
      newargs=("${newargs[@]:0:${#newargs[@]}-1}" --pattern "${base}" "$dir")
    else
      # handle implied extension
      newargs=("${newargs[@]:0:${#newargs[@]}-1}" --pattern "${base}(?:\..+)?$" "$dir")
    fi
    command erd "${newargs[@]}"
  fi
}
if [[ $OSTYPE != cygwin ]]; then
  alias ll='_erdtree -HI -d physical -s name -y inverted --long --no-ignore --no-progress -L1'
else
  # no permission info (erd --long) on non-unix
  alias ll='_erdtree -HI -d physical -s name -y inverted --no-ignore --no-progress -L1 "$@"'
fi
alias tree='_erdtree -HI -d physical -s name -y inverted --no-progress'

## File completion for aliases
#

# completion function for _open_file_explorer
function _files_completion() {
  _files -/  # Completes files and directories
}

if [[ -n "$ZSH_VERSION" ]]; then
  compdef _files_completion _open_file_explorer
  compdef _files_completion _erdtree
else
  complete -F _files_completion _open_file_explorer
  complete -F _files_completion _erdtree
fi
