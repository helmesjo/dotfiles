# Environment variables for linux-arch.
# Sourced by .zshrc/.bashrc via: set -a; source ~/.env; set +a

# System
LANG=en_US.UTF-8
LC_ALL=en_US.UTF-8
COLORTERM=truecolor

# Editor
VISUAL=hx
EDITOR=$VISUAL

# Zen Browser
XRE_PROFILE_PATH=~/.config/zen/13pmdhsh.fho
XRE_PROFILE_LOCAL_PATH=~/.cache/zen/profile
